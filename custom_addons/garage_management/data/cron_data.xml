<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Generate AI Reminders - runs daily -->
        <record id="ir_cron_generate_reminders" model="ir.cron">
            <field name="name">Garage: Generate AI Service Reminders</field>
            <field name="model_id" ref="model_garage_reminder"/>
            <field name="state">code</field>
            <field name="code">model.generate_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <!-- Send WhatsApp Reminders - runs daily -->
        <record id="ir_cron_send_reminders" model="ir.cron">
            <field name="name">Garage: Send WhatsApp Service Reminders</field>
            <field name="model_id" ref="model_garage_reminder"/>
            <field name="state">code</field>
            <field name="code">model.send_pending_reminders()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
