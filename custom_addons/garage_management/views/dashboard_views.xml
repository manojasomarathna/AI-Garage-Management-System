<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard Action using existing views with filters -->
    <record id="action_garage_dashboard_orders" model="ir.actions.act_window">
        <field name="name">Active Jobs</field>
        <field name="res_model">garage.service.order</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('state', 'not in', ['delivered', 'cancelled'])]</field>
        <field name="context">{'search_default_group_state': 1}</field>
    </record>

    <record id="action_garage_pending_reminders" model="ir.actions.act_window">
        <field name="name">Pending Reminders</field>
        <field name="res_model">garage.reminder</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'pending')]</field>
    </record>

</odoo>
