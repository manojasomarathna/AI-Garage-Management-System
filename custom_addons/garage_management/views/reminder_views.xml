<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_garage_reminder_list" model="ir.ui.view">
        <field name="name">garage.reminder.tree</field>
        <field name="model">garage.reminder</field>
        <field name="arch" type="xml">
            <tree string="Service Reminders"
                  decoration-danger="predicted_date &lt; current_date and state == 'pending'"
                  decoration-warning="state == 'pending'">
                <field name="vehicle_id"/>
                <field name="customer_id"/>
                <field name="reminder_type"/>
                <field name="predicted_date"/>
                <field name="state" widget="badge"
                       decoration-success="state=='done'"
                       decoration-warning="state=='pending'"
                       decoration-info="state=='sent'"/>
                <field name="notification_sent_date"/>
                <field name="notes"/>
            </tree>
        </field>
    </record>

    <record id="view_garage_reminder_form" model="ir.ui.view">
        <field name="name">garage.reminder.form</field>
        <field name="model">garage.reminder</field>
        <field name="arch" type="xml">
            <form string="Service Reminder">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,sent,booked,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="customer_id" readonly="1"/>
                            <field name="reminder_type"/>
                        </group>
                        <group>
                            <field name="predicted_date"/>
                            <field name="predicted_mileage"/>
                            <field name="notification_sent_date" readonly="1"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="AI prediction notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_garage_reminder" model="ir.actions.act_window">
        <field name="name">Service Reminders</field>
        <field name="res_model">garage.reminder</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
