<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vehicle Form View -->
    <record id="view_garage_vehicle_form" model="ir.ui.view">
        <field name="name">garage.vehicle.form</field>
        <field name="model">garage.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <button name="action_create_service_order" type="object"
                            string="New Service Order" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_service_orders" type="object"
                                class="oe_stat_button" icon="fa-wrench">
                            <field name="service_count" widget="statinfo" string="Services"/>
                        </button>
                    </div>
                    <group>
                        <group string="Vehicle Info">
                            <field name="license_plate"/>
                            <field name="brand"/>
                            <field name="model"/>
                            <field name="year"/>
                            <field name="color"/>
                            <field name="vehicle_type"/>
                            <field name="fuel_type"/>
                            <field name="vin"/>
                        </group>
                        <group string="Owner &amp; Service">
                            <field name="customer_id"/>
                            <field name="current_mileage"/>
                            <field name="last_service_date"/>
                            <field name="last_service_mileage"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Service History">
                            <field name="service_order_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="date_received"/>
                                    <field name="state"/>
                                    <field name="total_amount"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vehicle List View -->
    <record id="view_garage_vehicle_list" model="ir.ui.view">
        <field name="name">garage.vehicle.list</field>
        <field name="model">garage.vehicle</field>
        <field name="arch" type="xml">
            <list string="Vehicles">
                <field name="license_plate"/>
                <field name="brand"/>
                <field name="model"/>
                <field name="year"/>
                <field name="vehicle_type"/>
                <field name="customer_id"/>
                <field name="last_service_date"/>
                <field name="service_count"/>
            </list>
        </field>
    </record>

    <!-- Vehicle Search View -->
    <record id="view_garage_vehicle_search" model="ir.ui.view">
        <field name="name">garage.vehicle.search</field>
        <field name="model">garage.vehicle</field>
        <field name="arch" type="xml">
            <search>
                <field name="license_plate"/>
                <field name="brand"/>
                <field name="customer_id"/>
                <filter string="Cars" name="cars" domain="[('vehicle_type','=','car')]"/>
                <filter string="Vans" name="vans" domain="[('vehicle_type','=','van')]"/>
                <group expand="0" string="Group By">
                    <filter string="Brand" name="group_brand" context="{'group_by': 'brand'}"/>
                    <filter string="Vehicle Type" name="group_type" context="{'group_by': 'vehicle_type'}"/>
                    <filter string="Owner" name="group_owner" context="{'group_by': 'customer_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vehicle Action -->
    <record id="action_garage_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">garage.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_garage_vehicle_search"/>
    </record>

</odoo>
