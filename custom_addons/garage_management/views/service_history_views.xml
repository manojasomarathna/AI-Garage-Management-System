<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_garage_service_history_list" model="ir.ui.view">
        <field name="name">garage.service.history.list</field>
        <field name="model">garage.service.history</field>
        <field name="arch" type="xml">
            <tree string="Service History">
                <field name="service_date"/>
                <field name="vehicle_id"/>
                <field name="customer_id"/>
                <field name="mileage"/>
                <field name="work_summary"/>
                <field name="total_cost"/>
                <field name="next_service_date"/>
            </tree>
        </field>
    </record>

    <record id="view_garage_service_history_form" model="ir.ui.view">
        <field name="name">garage.service.history.form</field>
        <field name="model">garage.service.history</field>
        <field name="arch" type="xml">
            <form string="Service History">
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="customer_id" readonly="1"/>
                            <field name="service_order_id"/>
                            <field name="service_date"/>
                            <field name="mileage"/>
                            <field name="total_cost"/>
                        </group>
                        <group>
                            <field name="next_service_date"/>
                            <field name="next_service_mileage"/>
                        </group>
                    </group>
                    <group>
                        <field name="work_summary"/>
                        <field name="parts_replaced"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_garage_service_history" model="ir.actions.act_window">
        <field name="name">Service History</field>
        <field name="res_model">garage.service.history</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
