<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_garage_whatsapp_form" model="ir.ui.view">
        <field name="name">garage.whatsapp.form</field>
        <field name="model">garage.whatsapp</field>
        <field name="arch" type="xml">
            <form string="WhatsApp Configuration">
                <header>
                    <button name="action_test_connection" type="object"
                            string="Test Connection" class="btn-primary"/>
                </header>
                <sheet>
                    <group string="Twilio Credentials">
                        <field name="name"/>
                        <field name="account_sid"/>
                        <field name="auth_token" password="True"/>
                        <field name="from_number" placeholder="whatsapp:+1415XXXXXXX"/>
                    </group>
                    <group string="Garage Info">
                        <field name="garage_name"/>
                        <field name="garage_phone"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_garage_whatsapp_list" model="ir.ui.view">
        <field name="name">garage.whatsapp.list</field>
        <field name="model">garage.whatsapp</field>
        <field name="arch" type="xml">
            <list string="WhatsApp Configurations">
                <field name="name"/>
                <field name="garage_name"/>
                <field name="garage_phone"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_garage_whatsapp" model="ir.actions.act_window">
        <field name="name">WhatsApp Configuration</field>
        <field name="res_model">garage.whatsapp</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
